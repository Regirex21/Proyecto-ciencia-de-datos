---
export const prerender = false;

import '../styles/global.css';
import { supabase } from '../lib/supbase';

const { data } = await supabase.from('respuestas').select('*');
const respuestas = data || [];

const total = respuestas.length;

function limpiar(v: any) {
  if (!v) return '';
  return String(v).trim();
}

function contar(campo: string) {
  const mapa: Record<string, number> = {};

  respuestas.forEach((r: any) => {
    const valor = limpiar(r[campo]);
    if (valor) mapa[valor] = (mapa[valor] || 0) + 1;
  });

  return mapa;
}

function labels(obj: any) {
  return Object.keys(obj);
}

function values(obj: any) {
  return Object.values(obj);
}

const edades = respuestas
  .map((r: any) => Number(r.edad))
  .filter((n: number) => !isNaN(n) && n >= 15 && n <= 80);

const promedioEdad = edades.length
  ? (edades.reduce((a,b)=>a+b,0) / edades.length).toFixed(1)
  : 0;

const impulsivaSi = respuestas.filter((r:any)=>limpiar(r.compra_impulsiva)==='Si').length;
const arrepSi = respuestas.filter((r:any)=>limpiar(r.arrepentimiento)==='Si').length;

const porcentajeImp = total ? ((impulsivaSi/total)*100).toFixed(1) : 0;
const porcentajeArr = total ? ((arrepSi/total)*100).toFixed(1) : 0;

const genero = contar('genero');
const frecuencia = contar('frecuencia');
const tiempo = contar('tiempo');
const productosRaw = contar('productos');
const productos: Record<string, number> = {};

Object.entries(productosRaw).forEach(([key, value]) => {
  const limpio = String(key).trim().toLowerCase();
  let nueva = key;

  if (limpio === '01-mar') nueva = '1 a 3';
  else if (limpio === '04-oct') nueva = '4 a 10';
  else if (limpio === '1-3') nueva = '1 a 3';
  else if (limpio === '4-10') nueva = '4 a 10';
  else if (limpio.includes('mas de 10') || limpio.includes('más de 10')) nueva = 'Más de 10';

  productos[nueva] = (productos[nueva] || 0) + Number(value);
});
const emocion = contar('emocion');
const intensidad = contar('intensidad_emocion');
const publicidad = contar('publicidad');
const descuentos = contar('descuentos');
const dinero = contar('dinero');
const metodo = contar('metodo_pago');
const credito = contar('tarjeta_credito');
const escala = contar('escala');
const impulsiva = contar('compra_impulsiva');
const arrep = contar('arrepentimiento');
function contarMultiple(campo: string) {
  const mapa: Record<string, number> = {};

  respuestas.forEach((r: any) => {
    const valor = limpiar(r[campo]);
    if (!valor) return;

    valor.split(',').forEach((item: string) => {
      const opcion = item.trim();
      if (opcion) {
        mapa[opcion] = (mapa[opcion] || 0) + 1;
      }
    });
  });

  return mapa;
}

const ultima = contarMultiple('ultima_compra');
---

<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta http-equiv="refresh" content="30" />
<title>Resultados</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body class="bg-gray-100 p-8">

<div class="max-w-7xl mx-auto">

<h1 class="text-5xl font-bold mb-10">Resultados Encuesta</h1>

<!-- KPIs -->
<div class="grid md:grid-cols-4 gap-6 mb-10">

<div class="bg-white p-6 rounded-xl shadow">
<p class="text-gray-500">Total respuestas</p>
<p class="text-4xl font-bold">{total}</p>
</div>

<div class="bg-white p-6 rounded-xl shadow">
<p class="text-gray-500">Promedio edad</p>
<p class="text-4xl font-bold">{promedioEdad}</p>
</div>

<div class="bg-white p-6 rounded-xl shadow">
<p class="text-gray-500">% De Compra Impulsiva</p>
<p class="text-4xl font-bold">{porcentajeImp}%</p>
</div>

<div class="bg-white p-6 rounded-xl shadow">
<p class="text-gray-500">% De Arrepentimiento</p>
<p class="text-4xl font-bold">{porcentajeArr}%</p>
</div>

</div>

<!-- REEMPLAZA SOLO TU BLOQUE HTML DE GRAFICAS POR ESTE -->

<!-- GRAFICAS -->
<div class="grid md:grid-cols-2 gap-6">

<!-- FILA 1 -->
<div class="bg-white p-5 rounded-xl shadow h-[340px]">
  <h2 class="font-bold text-xl mb-3">Género</h2>
  <div class="h-[260px]"><canvas id="g1"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[340px]">
  <h2 class="font-bold text-xl mb-3">Frecuencia de compras no planeadas</h2>
  <div class="h-[260px]"><canvas id="g2"></canvas></div>
</div>

<!-- FILA 2 -->
<div class="bg-white p-5 rounded-xl shadow h-[340px]">
  <h2 class="font-bold text-xl mb-3">Tiempo viendo productos</h2>
  <div class="h-[260px]"><canvas id="g3"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[340px]">
  <h2 class="font-bold text-xl mb-3">Cantidad de productos revisados</h2>
  <div class="h-[260px]"><canvas id="g4"></canvas></div>
</div>

<!-- FILA 3 -->
<div class="bg-white p-5 rounded-xl shadow h-[420px]">
  <h2 class="font-bold text-xl mb-3">Emoción previa</h2>
  <div class="h-[340px]"><canvas id="g5"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[420px]">
  <h2 class="font-bold text-xl mb-3">Intensidad emocional</h2>
  <div class="h-[340px]"><canvas id="g6"></canvas></div>
</div>

<!-- FILA 4 -->
<div class="bg-white p-5 rounded-xl shadow h-[380px]">
  <h2 class="font-bold text-xl mb-3">Publicidad influyente</h2>
  <div class="h-[300px]"><canvas id="g7"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[380px]">
  <h2 class="font-bold text-xl mb-3">Descuentos aumentaron intención</h2>
  <div class="h-[300px]"><canvas id="g8"></canvas></div>
</div>

<!-- FILA 5 -->
<div class="bg-white p-5 rounded-xl shadow h-[380px]">
  <h2 class="font-bold text-xl mb-3">¿Tenías dinero suficiente?</h2>
  <div class="h-[300px]"><canvas id="g9"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[380px]">
  <h2 class="font-bold text-xl mb-3">Método de pago</h2>
  <div class="h-[300px]"><canvas id="g10"></canvas></div>
</div>

<!-- FILA 6 -->
<div class="bg-white p-5 rounded-xl shadow h-[380px]">
  <h2 class="font-bold text-xl mb-3">Crédito sin dinero</h2>
  <div class="h-[300px]"><canvas id="g11"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[380px]">
  <h2 class="font-bold text-xl mb-3">Disposición a endeudarte</h2>
  <div class="h-[300px]"><canvas id="g12"></canvas></div>
</div>

<!-- FILA 7 -->
<div class="bg-white p-5 rounded-xl shadow h-[360px]">
  <h2 class="font-bold text-xl mb-3">Compra impulsiva</h2>
  <div class="h-[280px]"><canvas id="g13"></canvas></div>
</div>

<div class="bg-white p-5 rounded-xl shadow h-[360px]">
  <h2 class="font-bold text-xl mb-3">Arrepentimiento</h2>
  <div class="h-[280px]"><canvas id="g14"></canvas></div>
</div>

<!-- FILA FINAL -->
<div class="bg-white p-5 rounded-xl shadow md:col-span-2 h-[520px]">
  <h2 class="font-bold text-xl mb-3">Última compra</h2>
  <div class="h-[440px]"><canvas id="g15"></canvas></div>
</div>

</div>

<script define:vars={{
genero, frecuencia, tiempo, productos, emocion, intensidad,
publicidad, descuentos, dinero, metodo, credito, escala,
impulsiva, arrep, ultima
}}>

function crear(id,tipo,obj){
new Chart(document.getElementById(id),{
type: tipo,
data:{
labels:Object.keys(obj),
datasets:[{
label:'Cantidad',
data:Object.values(obj)
}]
},
options:{
responsive:true,
maintainAspectRatio:false,
plugins:{legend:{display:true}}
}
});
}

document.addEventListener('DOMContentLoaded',()=>{

crear('g1','bar',genero);
crear('g2','bar',frecuencia);
crear('g3','bar',tiempo);
crear('g4','bar',productos);
crear('g5','doughnut',emocion);
crear('g6','line',intensidad);
crear('g7','bar',publicidad);
crear('g8','pie',descuentos);
crear('g9','pie',dinero);
crear('g10','bar',metodo);
crear('g11','pie',credito);
crear('g12','line',escala);
crear('g13','pie',impulsiva);
crear('g14','pie',arrep);
new Chart(document.getElementById('g15'),{
type:'bar',
data:{
labels:Object.keys(ultima),
datasets:[{
label:'Cantidad',
data:Object.values(ultima)
}]
},
options:{
indexAxis:'y',
responsive:true
}
});

});
</script>

</body>
</html>
