---
export const prerender = false;

import '../styles/global.css';
import { supabase } from '../lib/supbase';

let mensaje = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();

    const data = {
      edad: formData.get('edad'),
      genero: formData.get('genero'),
      frecuencia: formData.get('frecuencia'),
      tiempo: formData.get('tiempo'),
      productos: formData.get('productos'),
      emocion: formData.get('emocion'),
      intensidad_emocion: formData.get('intensidad_emocion'),
      publicidad: formData.get('publicidad'),
      descuentos: formData.get('descuentos'),
      dinero: formData.get('dinero'),
      metodo_pago: formData.get('metodo_pago'),
      tarjeta_credito: formData.get('tarjeta_credito'),
      escala: formData.get('escala'),
      compra_impulsiva: formData.get('compra_impulsiva'),
      arrepentimiento: formData.get('arrepentimiento'),
      ultima_compra: formData.getAll('ultima_compra').join(', ')
    };

        const { error } = await supabase
      .from('respuestas')
      .insert([data]);

    if (error) {
      console.log(error);
      mensaje = 'Error al guardar respuesta';
    } else {
      return Astro.redirect('/resultados');
    }

  } catch (err) {
    console.log(err);
    mensaje = 'Error al procesar formulario';
  }
}
---

<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Encuesta</title>
</head>

<body class="bg-purple-50 py-10">
<div class="max-w-3xl mx-auto px-4">

<div class="bg-white rounded-xl shadow p-8 border-t-8 border-purple-600 mb-6">
<h1 class="text-4xl font-bold mb-2">¿Qué tan manipulable somos?</h1>
<p class="text-gray-600">Predicción de compras impulsivas</p>
</div>

{mensaje && (
<div class="bg-green-100 text-green-700 p-4 rounded-xl mb-6">
{mensaje}
</div>
)}

<form method="POST" enctype="multipart/form-data" class="space-y-6">

<!-- Edad -->
<div class="bg-white rounded-xl shadow p-6">
<label class="font-semibold block mb-3">¿Qué edad tienes?</label>
<input name="edad" type="number" required class="w-full border-b-2 p-2 outline-none" />
</div>

<!-- Género -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">Género</p>
<label class="block"><input type="radio" name="genero" value="Masculino" required> Masculino</label>
<label class="block"><input type="radio" name="genero" value="Femenino"> Femenino</label>
<label class="block"><input type="radio" name="genero" value="Prefiero no decirlo"> Prefiero no decirlo</label>
</div>

<!-- Frecuencia -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Con qué frecuencia realizas compras no planeadas?</p>
<label class="block"><input type="radio" name="frecuencia" value="Rara vez" required> Rara vez</label>
<label class="block"><input type="radio" name="frecuencia" value="A veces"> A veces</label>
<label class="block"><input type="radio" name="frecuencia" value="Frecuentemente"> Frecuentemente</label>
<label class="block"><input type="radio" name="frecuencia" value="Nunca"> Nunca</label>
</div>

<!-- Tiempo -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Cuánto tiempo pasas viendo productos antes de comprar?</p>
<label class="block"><input type="radio" name="tiempo" value="2-3 minutos" required> De 2 a 3 minutos</label>
<label class="block"><input type="radio" name="tiempo" value="3-5 minutos"> De 3 a 5 minutos</label>
<label class="block"><input type="radio" name="tiempo" value="5-7 minutos"> De 5 a 7 minutos</label>
<label class="block"><input type="radio" name="tiempo" value="7-10 minutos"> De 7 a 10 minutos</label>
<label class="block"><input type="radio" name="tiempo" value="Más de 10 minutos"> Más de 10 minutos</label>
</div>

<!-- Productos revisados -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Cuántos productos revisas antes de decidir?</p>
<label class="block"><input type="radio" name="productos" value="1-3" required> 1-3</label>
<label class="block"><input type="radio" name="productos" value="4-10"> 4-10</label>
<label class="block"><input type="radio" name="productos" value="Más de 10"> Más de 10</label>
</div>

<!-- Emoción -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Cómo te sentías antes de tu última compra no planeada?</p>
<label class="block"><input type="radio" name="emocion" value="Feliz" required> Feliz</label>
<label class="block"><input type="radio" name="emocion" value="Triste"> Triste</label>
<label class="block"><input type="radio" name="emocion" value="Estresado"> Estresado</label>
<label class="block"><input type="radio" name="emocion" value="Aburrido"> Aburrido</label>
<label class="block"><input type="radio" name="emocion" value="Enojado"> Enojado</label>
</div>

<!-- Intensidad -->
<div class="bg-white rounded-xl shadow p-6">
<label class="font-semibold block mb-3">Intensidad emocional (1 al 10)</label>
<input name="intensidad_emocion" type="number" min="1" max="10" required class="w-full border-b-2 p-2 outline-none" />
</div>

<!-- Publicidad -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Qué publicidad influyó más?</p>
<label class="block"><input type="radio" name="publicidad" value="Descuentos" required> Descuentos</label>
<label class="block"><input type="radio" name="publicidad" value="Promociones"> Promociones</label>
<label class="block"><input type="radio" name="publicidad" value="Recomendaciones personalizadas"> Recomendaciones personalizadas</label>
<label class="block"><input type="radio" name="publicidad" value="Urgencia"> Urgencia</label>
<label class="block"><input type="radio" name="publicidad" value="Ninguna"> Ninguna</label>
</div>

<!-- Descuentos -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Los descuentos aumentaron tu intención de compra?</p>
<label class="block"><input type="radio" name="descuentos" value="Si" required> Sí</label>
<label class="block"><input type="radio" name="descuentos" value="No"> No</label>
<label class="block"><input type="radio" name="descuentos" value="No estoy seguro(a)"> No estoy seguro(a)</label>
</div>

<!-- Dinero -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Tenías dinero suficiente?</p>
<label class="block"><input type="radio" name="dinero" value="Si" required> Sí</label>
<label class="block"><input type="radio" name="dinero" value="No"> No</label>
<label class="block"><input type="radio" name="dinero" value="Más o menos"> Más o menos</label>
</div>

<!-- Pago -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Qué método de pago utilizaste?</p>
<label class="block"><input type="radio" name="metodo_pago" value="Efectivo" required> Efectivo</label>
<label class="block"><input type="radio" name="metodo_pago" value="Tarjeta de débito"> Tarjeta de débito</label>
<label class="block"><input type="radio" name="metodo_pago" value="Tarjeta de crédito"> Tarjeta de crédito</label>
</div>

<!-- Crédito -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">Si usaste crédito, ¿sin dinero suficiente?</p>
<label class="block"><input type="radio" name="tarjeta_credito" value="Si" required> Sí</label>
<label class="block"><input type="radio" name="tarjeta_credito" value="No"> No</label>
<label class="block"><input type="radio" name="tarjeta_credito" value="No aplica"> No aplica</label>
</div>

<!-- Endeudarse -->
<div class="bg-white rounded-xl shadow p-6">
<label class="font-semibold block mb-3">Disposición a endeudarte (1 al 10)</label>
<input name="escala" type="number" min="1" max="10" required class="w-full border-b-2 p-2 outline-none" />
</div>

<!-- Impulsiva -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Consideras que fue impulsiva?</p>
<label class="block"><input type="radio" name="compra_impulsiva" value="Si" required> Sí</label>
<label class="block"><input type="radio" name="compra_impulsiva" value="No"> No</label>
</div>

<!-- Arrepentimiento -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Te arrepentiste después?</p>
<label class="block"><input type="radio" name="arrepentimiento" value="Si" required> Sí</label>
<label class="block"><input type="radio" name="arrepentimiento" value="No"> No</label>
</div>

<!-- Última compra -->
<div class="bg-white rounded-xl shadow p-6">
<p class="font-semibold mb-3">¿Qué fue lo último que compraste?</p>
<label class="block"><input type="checkbox" name="ultima_compra" value="Snacks"> Snacks</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Ropa"> Ropa</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Aparatos electrónicos"> Aparatos electrónicos</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Zapatos"> Zapatos</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Artículos decorativos"> Artículos decorativos</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Accesorios para celular"> Accesorios para celular</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Cosméticos"> Cosméticos</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Herramientas"> Herramientas</label>
<label class="block"><input type="checkbox" name="ultima_compra" value="Insumos"> Insumos</label>
</div>

<button class="w-full bg-purple-600 hover:bg-purple-700 text-white p-4 rounded-xl font-semibold">
Enviar encuesta
</button>

</form>
</div>
</body>
</html>